# =============================================================================
# Accetraa Technologies — Environment Variables Template
#
# Copy this file to .env and fill in the real values for your environment.
#   cp .env.example .env
#
# IMPORTANT: Never commit .env — it is excluded in .gitignore.
# This file (.env.example) contains ONLY placeholders and IS committed.
# =============================================================================


# =============================================================================
# DJANGO CORE
# =============================================================================

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-50-character-random-secret-key-here

# Settings module to load. Options:
#   accetraa.settings.development   ← local dev (MySQL, console email)
#   accetraa.settings.staging       ← Render free tier (PostgreSQL, no AWS)
#   accetraa.settings.production    ← production server (MySQL, AWS SES email)
DJANGO_SETTINGS_MODULE=accetraa.settings.development

# Set to False in staging and production
DEBUG=True

# Comma-separated. Production example: accetraa.com,www.accetraa.com,api.accetraa.com
# Staging example: accetraa-staging-api.onrender.com,localhost
ALLOWED_HOSTS=localhost,127.0.0.1


# =============================================================================
# STAGING MODE (staging.py only)
# =============================================================================

# Disables submission endpoints (contact / consultation / demo-requests) when True.
# Set to False or remove entirely to re-enable for production.
STAGING_MODE=True


# =============================================================================
# DATABASE — MySQL (development.py and production.py)
# =============================================================================

DB_NAME=accetraa_db
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=3306


# =============================================================================
# DATABASE — PostgreSQL (staging.py only)
# =============================================================================

# Injected automatically by Render when the PostgreSQL service is linked.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Leave blank in development (MySQL is used instead).
DATABASE_URL=


# =============================================================================
# CORS — Allowed Frontend Origins
# =============================================================================

# Development:  http://localhost:5173,http://localhost:3000
# Staging:      https://<project>.vercel.app
# Production:   https://accetraa.com,https://www.accetraa.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# =============================================================================
# EMAIL — Backend selection
# =============================================================================

# Development  → prints emails to the terminal (no credentials needed)
# Staging      → silently discards all emails (overridden in staging.py)
# Production   → AWS SES (set EMAIL_BACKEND=django_ses.SESBackend + AWS credentials below)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# The "From" address shown on all outbound emails.
# Since accetraa.com is verified in SES, use any @accetraa.com address here.
# Notifications still arrive at CONTACT_EMAIL (businessaccetraacompany@gmail.com).
EMAIL_FROM=no-reply@accetraa.com

# All form-submission notifications are sent to this single address.
SALES_EMAIL=businessaccetraacompany@gmail.com
CONTACT_EMAIL=businessaccetraacompany@gmail.com
HR_EMAIL=businessaccetraacompany@gmail.com


# =============================================================================
# AWS — IAM Credentials (shared by SES and S3)
# =============================================================================
#
# How to create an IAM user with the right permissions:
#   1. AWS Console → IAM → Users → Create user
#   2. Enable "Programmatic access" to get an access key + secret
#   3. Attach the following inline/managed policies:
#        SES send:  see policy JSON in the SES section below
#        S3 access: AmazonS3FullAccess (or a scoped bucket policy)
#   4. Copy the key pair now — the secret is shown only once
#
# Leave blank in development and staging (those settings use console/dummy backends).
AWS_ACCESS_KEY_ID=your-iam-access-key-id
AWS_SECRET_ACCESS_KEY=your-iam-secret-access-key


# =============================================================================
# AWS SES — Email sending (production only)
# =============================================================================
#
# Minimum IAM policy to attach to the IAM user above:
#
#   {
#     "Version": "2012-10-17",
#     "Statement": [{
#       "Effect":   "Allow",
#       "Action":   ["ses:SendEmail", "ses:SendRawEmail"],
#       "Resource": "*"
#     }]
#   }
#
# Setup steps:
#   1. AWS Console → Simple Email Service (SES) → Verified identities
#   2. "Create identity" → choose "Email address"
#   3. Enter the sender address (should match EMAIL_FROM above) → click Verify
#   4. Open your inbox and click the verification link AWS sends you
#   5. If your AWS account is still in SES sandbox mode:
#        - Also verify EVERY recipient address the same way, OR
#        - Request production access: SES → Account dashboard → "Request production access"
#          (approval usually takes 24 h; explain you are sending transactional email)
#   6. Set AWS_SES_REGION_NAME to the region you used when creating the identity
#
# Once verified, set these in your production environment:
#   EMAIL_BACKEND=django_ses.SESBackend
#   EMAIL_FROM=no-reply@accetraa.com
#   AWS_ACCESS_KEY_ID=<from IAM step above>
#   AWS_SECRET_ACCESS_KEY=<from IAM step above>
AWS_SES_REGION_NAME=ap-south-1


# =============================================================================
# AWS S3 — File storage (optional — for portfolio/product images)
# =============================================================================
# S3 is only activated when AWS_S3_BUCKET_NAME is provided.
# Leave blank to use local disk storage — fine for email-only AWS setups.
AWS_S3_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1

# CloudFront CDN domain for serving media files (optional).
# Omit entirely if you are not using CloudFront.
AWS_CLOUDFRONT_DOMAIN=
