# =============================================================================
# Accetraa Technologies — Frontend Environment Variables Template
#
# Copy this file to .env and fill in the real values for your environment.
#   cp .env.example .env
#
# IMPORTANT: Never commit .env — it is excluded in .gitignore.
# =============================================================================


# =============================================================================
# API
# =============================================================================

# Backend API base URL.
# Development:  leave blank (Vite proxy forwards /api/* to localhost:8000)
# Staging:      https://<render-service>.onrender.com
# Production:   https://api.accetraa.com
VITE_API_BASE_URL=


# =============================================================================
# APP
# =============================================================================

VITE_APP_NAME=Accetraa


# =============================================================================
# STAGING MODE
# =============================================================================

# Set to "true" on Vercel staging deployment.
# Replaces live contact / consultation / demo request forms with informational
# notices. Set to "false" or remove entirely for production.
VITE_STAGING_MODE=false
